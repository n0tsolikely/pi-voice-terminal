# Copy this file to .env and fill in your real key.
# Local Vosk is the preferred Raspberry Pi STT path. If it is unavailable, OpenAI can still handle one-shot transcription.
OPENAI_API_KEY=your_key_here
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_API_BASE=https://api.openai.com/v1

# STT provider: auto, local, or openai
STT_PROVIDER=auto
VOSK_MODEL_PATH=.local-stt/models/vosk-model-small-en-us-0.15
LOCAL_STT_LANGUAGE=en
LOCAL_STT_PYTHON=.local-stt-venv/bin/python

# TTS provider: auto, openai, piper, espeak, or local
TTS_PROVIDER=auto
PIPER_BIN=piper
PIPER_VOICE_MODEL=
ESPEAK_VOICE=en-us

# Optional shell overrides:
# PI_SHELL=/bin/bash
# PI_SHELL_ARGS=-l
# PI_WORKDIR=/home/pi
